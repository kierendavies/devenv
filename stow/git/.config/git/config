[core]
    editor = nvim

[diff]
    algorithm = histogram
    external = difft

[init]
    defaultBranch = main

[merge]
    conflictStyle = diff3

[merge "mergiraf"]
    name = mergiraf
    driver = mergiraf merge --git %O %A %B -s %S -x %X -y %Y -p %P -l %L

[pull]
    ff = only

[push]
    autoSetupRemote = true

[rebase]
    autoSquash = true
    autoStash = true

[user]
    useConfigOnly = true

[include]
    path = alias.conf
    path = user.conf

    # Enable environment-specific overrides, e.g. to use a work email address,
    # without modifying any versioned files. This must be the last declaration
    # in this file.
    path = override.conf
